# Arbitrout + Lobsterminal Environment Variables
# Copy to .env and fill in your keys. NEVER commit .env to git.

# ── Trading Mode ──────────────────────────────────────────
# Set to "false" for live trading (default: true = paper mode)
PAPER_TRADING=true
# PAPER_STARTING_BALANCE=10000

# ── Polymarket (required for live trading) ────────────────
# Your Polygon private key (hex string, no 0x prefix)
POLYMARKET_PRIVATE_KEY=
# Your funding wallet address
POLYMARKET_FUNDER_ADDRESS=

# ── Kalshi (optional — public API works without keys) ─────
# With key: full access to trading API. Without: read-only public markets.
KALSHI_API_KEY=
KALSHI_RSA_PRIVATE_KEY=

# ── Coinbase Advanced Trade (optional) ────────────────────
COINBASE_ADV_API_KEY=
COINBASE_ADV_API_SECRET=

# ── PredictIt (optional) ──────────────────────────────────
PREDICTIT_SESSION=

# ── Local LLM (Ollama — e.g. Gemma 4) ─────────────────────
# Pull:  ollama pull gemma4
# When OLLAMA_API_KEY is non-empty, Ollama is tried LAST (OpenAI-compatible API)
# after Groq/Gemini/OpenRouter/Anthropic — backup when keys are missing or calls fail.
# Use any placeholder token; Ollama does not validate it.
# OLLAMA_API_KEY=ollama
# OLLAMA_CHAT_MODEL=gemma4
# Larger / MoE: gemma4:31b, gemma4:26b — see https://ollama.com/library/gemma4
# OLLAMA_OPENAI_URL=http://127.0.0.1:11434/v1/chat/completions
# Legacy native Ollama JSON API (Lobsterminal swarm / stock screen intent parser only):
# OLLAMA_URL=http://127.0.0.1:11434/api/chat
# OLLAMA_MODEL=gemma4

# ── AI Advisor (exit trigger review — tries in order) ─────
# Groq → Gemini → OpenRouter → Anthropic (live only) → Ollama last if OLLAMA_API_KEY set
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# ── News Scanner AI (optional — separate keys for independent rate limits)
# Falls back to the AI Advisor keys above if not set
# NEWS_GROQ_API_KEY=
# NEWS_GEMINI_API_KEY=
# NEWS_OPENROUTER_API_KEY=
# NEWS_ANTHROPIC_API_KEY=

# ── Opinion Labs (optional — requires API key) ───────────
# Get key at https://opinion.trade
OPINION_LABS_API_KEY=

# ── Server Auth ───────────────────────────────────────────
LOBSTERMINAL_API_KEY=dev-local-only

# ── Data APIs (Lobsterminal) ──────────────────────────────
FMP_API_KEY=
FINNHUB_API_KEY=
FINANCIAL_DATASETS_API_KEY=
